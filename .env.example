# ========================================
# Magnus-OS2 Environment Variables
# ========================================

# PostgreSQL Configuration
POSTGRES_DB=magnus
POSTGRES_USER=magnus
POSTGRES_PASSWORD=your_secure_password_here

# API Configuration
NODE_ENV=production
PORT=3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database URL (constructed from above values)
# DATABASE_URL=postgresql://magnus:your_secure_password_here@postgres:5432/magnus
