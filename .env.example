# ========================================
# Magnus-OS2 Environment Variables
# ========================================
# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

# ---- PostgreSQL ----
POSTGRES_DB=magnus
POSTGRES_USER=magnus
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ---- API ----
NODE_ENV=production
PORT=4000
CORS_ORIGINS=http://localhost:4000

# ---- Database URL (se construye desde los valores anteriores) ----
DATABASE_URL=postgresql://magnus:CHANGE_ME_USE_STRONG_PASSWORD@postgres:5432/magnus

# ---- JWT (generar con: openssl rand -base64 32) ----
JWT_SECRET=CHANGE_ME_USE_STRONG_SECRET

# ---- Flags opcionales ----
# DATABASE_SSL=false
# ALLOW_FIRST_ADMIN=false
GEMINI_API_KEY=
